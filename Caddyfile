{
	servers {
		trusted_proxies cloudflare
	}
}

www.ruanfailache.dev {
	redir https://ruanfailache.dev{uri} permanent
}

ruanfailache.dev {
	@api path /api/*

	# API endpoints get a tighter limit — 10 req/min per IP
	rate_limit @api {remote_host} 10/m

	# General browsing — 120 req/min per IP (2/s, covers normal page loads)
	rate_limit {remote_host} 120/m

	header {
		X-Content-Type-Options    nosniff
		X-Frame-Options           DENY
		Referrer-Policy           strict-origin-when-cross-origin
		Permissions-Policy        "geolocation=(), camera=(), microphone=()"
		-Server
	}

	reverse_proxy portfolio:3000
}
