{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Client and side projects — body field is Markdown (for side projects)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "projectType": {
      "type": "enumeration",
      "enum": ["client", "side"],
      "required": true,
      "default": "client"
    },
    "company": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "status": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "color": {
      "type": "enumeration",
      "enum": ["indigo", "sage", "rose", "amber"],
      "default": "indigo",
      "required": true
    },
    "desc": {
      "type": "text",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "outcome": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "tags": {
      "type": "json"
    },
    "body": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
